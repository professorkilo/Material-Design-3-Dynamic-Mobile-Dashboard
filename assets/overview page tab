            {{ is_state('group.all_light_switches', 'on') or
            is_state('light.all_lights', 'on') or  is_state('group.all_fans',
            'on') or is_state('group.all_doors', 'on') or
            is_state('group.all_windows', 'on') }}
      card:
        type: vertical-stack
        cards:
          - type: custom:streamline-card
            template: entity_count_card
            variables:
              - entity: light.all_lights_count_only
