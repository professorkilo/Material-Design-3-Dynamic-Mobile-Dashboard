                        ${vars[0] === 'heat' ? '#FF6F22' : 
                          (vars[0] === 'cool' ? '#2196F3' : 
                          (vars[0] === 'fan_only' ? '#029688' : 
                          (vars[1] < 13 ? '#B4A5B7' :
                          (vars[1] < 16 ? '#DBC9DE' :
                          (vars[1] < 19 ? '#ACDCF6' :
                          (vars[1] < 22 ? '#D2E5DE' :
                          (vars[1] < 24 ? '#FFE7A3' :
                          (vars[1] < 27 ? '#F7C48D' : '#E37575'))))))))}
                    - entity: sensor.outdoor_temperature
                      name: Outdoor
                      color: |-
                        ${vars[2] < 13 ? '#988C9B' :
                          (vars[2] < 16 ? '#BAABBD' :        
                          (vars[2] < 19 ? '#92BBD1' :
                          (vars[2] < 22 ? '#B2C4BD' :
                          (vars[2] < 24 ? '#D8C48A' :
                          (vars[2] < 27 ? '#D2A676' :'#C26161')))))}
